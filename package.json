{
	"name": "orpi-prop-gen",
	"private": true,
	"version": "1.1.3",
	"description": "Orpi PropGen — Générateur de propositions locatives",
	"author": "Orpi",
	"type": "module",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"electron:start": "electron .",
		"dist": "npm run build && electron-builder",
		"dist:win": "npm run build && electron-builder --win",
		"dist:mac": "npm run build && electron-builder --mac",
		"dist:all": "npm run build && electron-builder -mw",
		"release": "npm run build && electron-builder --publish always"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"electron": "^41.2.0",
		"electron-builder": "^26.8.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.4.0",
		"jsdom": "^29.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"dexie": "^4.4.2",
		"electron-log": "^5.4.3",
		"electron-updater": "^6.8.3",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1"
	},
	"build": {
		"appId": "com.orpi.propgen",
		"productName": "Orpi PropGen",
		"copyright": "Copyright © 2026 Orpi",
		"directories": {
			"buildResources": "installer",
			"output": "dist"
		},
		"files": [
			"electron/**/*",
			"build/**/*",
			"package.json",
			"!**/*.map",
			"!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}"
		],
		"publish": [
			{
				"provider": "github",
				"owner": "orpi-tools",
				"repo": "orpi-prop-gen-releases",
				"releaseType": "release"
			}
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": ["x64"]
				}
			],
			"artifactName": "OrpiPropGen-Setup-${version}.${ext}"
		},
		"nsis": {
			"oneClick": false,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "Orpi PropGen"
		},
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": ["x64", "arm64"]
				}
			],
			"category": "public.app-category.productivity",
			"artifactName": "OrpiPropGen-${version}-${arch}.${ext}"
		},
		"dmg": {
			"title": "Orpi PropGen ${version}"
		}
	}
}
